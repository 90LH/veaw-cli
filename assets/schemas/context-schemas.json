{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://veaw.local/schemas/context-schemas.json",
  "title": "VEAW Phase Two Context Schemas",
  "type": "object",
  "required": ["version", "schemas"],
  "properties": {
    "version": { "const": "1.0.0" },
    "schemas": {
      "type": "object",
      "required": ["screenshot-context", "component-query-result", "ui-component-context", "design-context", "task-list", "review-result"],
      "properties": {
        "screenshot-context": { "$ref": "#/$defs/screenshotContext" },
        "component-query-result": { "$ref": "#/$defs/componentQueryResult" },
        "ui-component-context": { "$ref": "#/$defs/uiComponentContext" },
        "design-context": { "$ref": "#/$defs/designContext" },
        "task-list": { "$ref": "#/$defs/taskList" },
        "review-result": { "$ref": "#/$defs/reviewResult" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "evidence": {
      "type": "object",
      "required": ["source", "ref", "note", "confidence"],
      "properties": {
        "source": { "enum": ["screenshot", "catalog", "mcp", "project", "context", "file", "generated"] },
        "ref": { "type": "string" },
        "note": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "degradation": {
      "type": "object",
      "required": ["code", "reason", "fallback"],
      "properties": {
        "code": { "type": "string" },
        "reason": { "type": "string" },
        "fallback": { "type": "string" }
      },
      "additionalProperties": false
    },
    "componentApi": {
      "type": "object",
      "required": ["props", "emits", "slots"],
      "properties": {
        "props": { "type": "array", "items": { "type": "string" } },
        "emits": { "type": "array", "items": { "type": "string" } },
        "slots": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "componentCandidate": {
      "type": "object",
      "required": ["name", "source", "reference", "api", "examples", "dependencies", "usageHints", "matchReason", "evidence"],
      "properties": {
        "name": { "type": "string" },
        "source": { "enum": ["catalog", "mcp"] },
        "reference": { "type": "string" },
        "category": { "type": "string" },
        "isShared": { "type": "boolean" },
        "api": { "$ref": "#/$defs/componentApi" },
        "examples": { "type": "array", "items": { "type": "string" } },
        "dependencies": { "type": "array", "items": { "type": "string" } },
        "usageHints": { "type": "array", "items": { "type": "string" } },
        "matchReason": { "type": "string" },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } }
      },
      "additionalProperties": false
    },
    "screenshotContext": {
      "type": "object",
      "required": ["schema", "version", "generatedAt", "available", "source", "permission", "relatedComponents", "observations", "evidence", "degradations"],
      "properties": {
        "schema": { "const": "screenshot-context" },
        "version": { "const": "1.0.0" },
        "generatedAt": { "type": "string" },
        "available": { "type": "boolean" },
        "reference": { "type": "string" },
        "route": { "type": "string" },
        "viewport": { "type": "string" },
        "source": { "enum": ["user-provided", "local-test", "missing"] },
        "permission": { "enum": ["explicit", "not-provided"] },
        "relatedComponents": { "type": "array", "items": { "type": "string" } },
        "observations": { "type": "array", "items": { "type": "object" } },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } },
        "degradations": { "type": "array", "items": { "$ref": "#/$defs/degradation" } }
      },
      "additionalProperties": false
    },
    "componentQueryResult": {
      "type": "object",
      "required": ["schema", "version", "query", "candidates", "evidence", "degradations"],
      "properties": {
        "schema": { "const": "component-query-result" },
        "version": { "const": "1.0.0" },
        "query": { "type": "string" },
        "candidates": { "type": "array", "items": { "$ref": "#/$defs/componentCandidate" } },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } },
        "degradations": { "type": "array", "items": { "$ref": "#/$defs/degradation" } }
      },
      "additionalProperties": false
    },
    "uiComponentContext": {
      "type": "object",
      "required": ["schema", "version", "generatedAt", "screenshot", "candidates", "risks", "uncertainties", "alternatives", "degradations"],
      "properties": {
        "schema": { "const": "ui-component-context" },
        "version": { "const": "1.0.0" },
        "generatedAt": { "type": "string" },
        "screenshot": { "$ref": "#/$defs/screenshotContext" },
        "candidates": { "type": "array", "items": { "$ref": "#/$defs/componentCandidate" } },
        "risks": { "type": "array", "items": { "type": "string" } },
        "uncertainties": { "type": "array", "items": { "type": "string" } },
        "alternatives": { "type": "array", "items": { "type": "string" } },
        "degradations": { "type": "array", "items": { "$ref": "#/$defs/degradation" } }
      },
      "additionalProperties": false
    },
    "designContext": {
      "type": "object",
      "required": ["schema", "version", "requirement", "layout", "interactions", "responsive", "componentReuse", "constraints", "uncertainties", "evidence", "degradations"],
      "properties": {
        "schema": { "const": "design-context" },
        "version": { "const": "1.0.0" },
        "requirement": { "type": "string" },
        "layout": { "type": "array", "items": { "type": "string" } },
        "interactions": { "type": "array", "items": { "type": "string" } },
        "responsive": { "type": "array", "items": { "type": "string" } },
        "componentReuse": { "type": "array", "items": { "$ref": "#/$defs/componentCandidate" } },
        "constraints": { "type": "array", "items": { "type": "string" } },
        "uncertainties": { "type": "array", "items": { "type": "string" } },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } },
        "degradations": { "type": "array", "items": { "$ref": "#/$defs/degradation" } }
      },
      "additionalProperties": false
    },
    "taskList": {
      "type": "object",
      "required": ["schema", "version", "requirement", "tasks", "degradations"],
      "properties": {
        "schema": { "const": "task-list" },
        "version": { "const": "1.0.0" },
        "requirement": { "type": "string" },
        "tasks": { "type": "array", "items": { "type": "object" } },
        "degradations": { "type": "array", "items": { "$ref": "#/$defs/degradation" } }
      },
      "additionalProperties": false
    },
    "reviewResult": {
      "type": "object",
      "required": ["schema", "version", "ok", "findings", "residualRisks", "testGaps"],
      "properties": {
        "schema": { "const": "review-result" },
        "version": { "const": "1.0.0" },
        "ok": { "type": "boolean" },
        "findings": { "type": "array", "items": { "type": "object" } },
        "residualRisks": { "type": "array", "items": { "type": "string" } },
        "testGaps": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  }
}
